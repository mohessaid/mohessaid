---
import ProjectDetail from '@/layouts/ProjectDetail.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', (p) => p.data.lang === 'ar');
  return projects.map((project) => {
    const slug = project.id.replace(/^ar\//, '');
    return { params: { slug }, props: { project } };
  });
}

const { project } = Astro.props;
const { Content } = await render(project);
const slug = project.id.replace(/^ar\//, '');
const canonicalURL = `https://mohessaid.com/projects/${slug}/`;
---

<ProjectDetail
  title={project.data.title}
  description={project.data.description}
  lang="ar"
  statusLabel={project.data.statusLabel}
  statusColor={project.data.statusColor}
  startDate={project.data.startDate}
  endDate={project.data.endDate}
  projectId={project.id}
  url={project.data.url}
  github={project.data.github}
  tech={project.data.tech}
  canonicalURL={canonicalURL}
>
  <Content />
</ProjectDetail>
