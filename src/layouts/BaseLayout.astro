---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  lang: 'ar' | 'en';
  dir?: 'rtl' | 'ltr';
  canonicalURL?: string;
}

const {
  title,
  lang,
  dir = lang === 'ar' ? 'rtl' : 'ltr',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props;

const defaultDescription = lang === 'ar'
  ? 'محمد السعيد مزرق — مهندس برمجيات. PHP، Go، JavaScript، Ruby. رؤى تقنية ومشاريع.'
  : 'Mohammed Essaid — Software Engineer working with PHP, Go, JavaScript & Ruby. Tech essays and projects.';

const description = Astro.props.description ?? defaultDescription;

const ogImage = new URL('/web-app-manifest-512x512.png', Astro.site).href;

const fullTitle = title === 'محمد السعيد مزرق' || title === 'Mohessaid'
  ? title
  : `${title} — محمد السعيد مزرق`;

// Compute hreflang alternate URLs from the current pathname
const pathname = Astro.url.pathname;
const siteBase = 'https://mohessaid.com';
const isEnPath = pathname.startsWith('/en/') || pathname === '/en';
const arUrl = isEnPath
  ? siteBase + (pathname.replace(/^\/en/, '') || '/')
  : canonicalURL;
const enUrl = isEnPath
  ? canonicalURL
  : siteBase + '/en' + (pathname === '/' ? '/' : pathname);

// Base JSON-LD: WebSite + Person (present on every page)
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteBase}/#website`,
      url: siteBase,
      name: 'Mohessaid',
      description: 'Mohammed Essaid — Software Engineer. Tech essays and projects.',
      author: { '@id': `${siteBase}/#person` },
      inLanguage: ['ar', 'en'],
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: `${siteBase}/en/?q={search_term_string}` },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Person',
      '@id': `${siteBase}/#person`,
      name: 'Mohammed Essaid',
      alternateName: ['Mohessaid', 'محمد السعيد مزرق', 'Mohammed Essaid MEZERREG'],
      url: siteBase,
      jobTitle: 'Software Engineer',
      knowsAbout: ['PHP', 'Go', 'JavaScript', 'Ruby', 'Elixir', 'Python', 'Software Engineering'],
      sameAs: [
        'https://github.com/mohessaid',
        'https://linkedin.com/in/mohessaid',
        'https://x.com/mohessaid',
      ],
    },
  ],
};

// ASCII-safe JSON encoding
const toSafeJson = (obj: unknown) =>
  JSON.stringify(obj).replace(/[^\x00-\x7F]/g, (c) =>
    '\\u' + c.codePointAt(0)!.toString(16).padStart(4, '0')
  );

const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang={lang} dir={dir} data-theme="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Mohammed Essaid MEZERREG" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang alternates for bilingual SEO -->
    <link rel="alternate" hreflang="ar" href={arUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={arUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'ar' ? 'ar_DZ' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'ar' ? 'en_US' : 'ar_DZ'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:site_name" content="Mohessaid" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@mohessaid" />
    <meta name="twitter:creator" content="@mohessaid" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts: preconnect then load only 2 families/weights -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500&family=Lalezar&display=swap"
    />

    <title>{fullTitle}</title>

    <!-- Base structured data: WebSite + Person (every page) -->
    <script is:inline type="application/ld+json" set:html={toSafeJson(siteJsonLd)} />

    <!-- Page-specific structured data injected by individual pages -->
    <slot name="head" />

    <!-- Google Analytics 4 (set PUBLIC_GA_ID env var to enable) -->
    {gaId && (
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){window.dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId, { anonymize_ip: true });
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        document.head.appendChild(s);
      </script>
    )}

    <!-- Theme detection: runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
      // Before each view-transition swap, copy the live theme onto the
      // incoming document so Astro doesn't reset it to the empty default.
      document.addEventListener('astro:before-swap', function (e) {
        var theme = document.documentElement.getAttribute('data-theme');
        if (theme) e.newDocument.documentElement.setAttribute('data-theme', theme);
      });
    </script>
    <ClientRouter />
  </head>
  <body>
    <slot name="header">
      <!-- default header injected by pages -->
    </slot>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="container">
        <span>{lang === 'ar' ? `© ${new Date().getFullYear()} محمد السعيد مزرق` : `© ${new Date().getFullYear()} Mohammed Essaid`}</span>
        <nav class="social-links" aria-label={lang === 'ar' ? 'روابط التواصل' : 'Social links'}>
          <a href="https://github.com/mohessaid" target="_blank" rel="noopener" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
          <a href="https://linkedin.com/in/mohessaid" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://x.com/mohessaid" target="_blank" rel="noopener" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
            </svg>
          </a>
        </nav>
      </div>
    </footer>
  </body>
</html>
